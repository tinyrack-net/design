---
import type { ListProps } from './props.js';
import { mergeClassNames } from '../shared.js';

interface Props extends ListProps {}

const { class: classAttribute, className, ...listProps } = Astro.props;
const classText = mergeClassNames(classAttribute, className);
---

<ul
  {...listProps}
  class={mergeClassNames(
    'tr-mdx-list',
    classText.includes('contains-task-list') && 'tr-mdx-task-list',
    classText,
  )}
>
  <slot />
</ul>
